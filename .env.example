# ============================================================
# Inference Gateway — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── Gateway Server ──────────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_WORKERS=1
GATEWAY_LOG_LEVEL=info          # debug | info | warning | error
GATEWAY_ENV=development         # development | production

# ── Authentication ──────────────────────────────────────────
GATEWAY_AUTH_ENABLED=true

# ── Rate Limiting ───────────────────────────────────────────
GATEWAY_DEFAULT_RATE_LIMIT_RPM=60

# ── Free Backend API Keys (sign up for free, no CC needed) ──
# Groq:        https://console.groq.com
GROQ_API_KEY=

# OpenRouter:  https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Google Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── BYOK: Users' Own API Keys (optional) ────────────────────
# Add your own keys for paid providers if you want
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# PPLX_API_KEY=

# ── Config Paths ────────────────────────────────────────────
GATEWAY_ROUTES_CONFIG=configs/routes.yaml
GATEWAY_AB_TESTS_CONFIG=configs/ab_tests.yaml
GATEWAY_TENANTS_CONFIG=configs/tenants.yaml
